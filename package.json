{
  "name": "ascii-qr",
  "version": "0.1.0",
  "type": "module",
  "description": "Typographic QR code generator — ASCII art QR codes that actually scan",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:demo": "vite build --mode demo",
    "preview": "vite preview",
    "deploy": "npm run build:demo && gh-pages -d dist-demo"
  },
  "keywords": [
    "qr",
    "qrcode",
    "ascii",
    "art",
    "typographic",
    "generator"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nichochar/ascii-qr"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "barcode-detector": "^3.1.1",
    "qrcode": "^1.5.4"
  }
}
